# 岁己SUI 微博监控 - 环境变量配置
# 复制为 .env 并填写实际值

# ===== 必填 =====
# 微博 Cookie（从 m.weibo.cn 登录后 F12 复制）
WEIBO_COOKIE=SUBP=...; SCF=...; SUB=...; XSRF-TOKEN=...

# ===== 可选 =====
# Telegram Bot（不填则不推送）
TG_BOT_TOKEN=
TG_CHAT_ID=

# 微博超话 Container ID（默认岁己SUI）
WEIBO_CONTAINERID=100808f7e22e5e7435023544d44d473e414c10

# 轮询间隔（秒）
CHECK_INTERVAL=15

# 请求超时（秒）
REQUEST_TIMEOUT=15

# 最大重试次数
RETRY_COUNT=3

# 日界限小时（岁己作息 ~11:00起 ~03:00睡，凌晨4:00分界）
DAY_BOUNDARY_HOUR=4

# 日志级别 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# 心跳（每天8点发送状态摘要）
HEARTBEAT_ENABLED=true
HEARTBEAT_HOUR=8
